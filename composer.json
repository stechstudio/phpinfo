{
  "name": "stechstudio/phpinfo",
  "description": "A beautiful, searchable replacement for phpinfo() with a clean programmatic API",
  "type": "library",
  "license": "MIT",
  "keywords": ["phpinfo", "php-info", "server-info", "configuration", "pretty-phpinfo"],
  "homepage": "https://prettyphpinfo.com",
  "support": {
    "issues": "https://github.com/stechstudio/phpinfo/issues",
    "source": "https://github.com/stechstudio/phpinfo"
  },
  "autoload": {
    "files": ["helpers.php"],
    "psr-4": {
      "STS\\Phpinfo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "STS\\Phpinfo\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Joseph Szobody",
      "email": "joseph@stechstudio.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-dom": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0|^12.0",
    "laravel/pint": "^1.29"
  }
}
